{
  "name": "marcusrbrown.com",
  "version": "0.0.0",
  "description": "Personal brand site for Marcus R. Brown.",
  "keywords": [
    "brand",
    "developer",
    "vite",
    "typescript",
    "react",
    "github-pages"
  ],
  "homepage": "https://marcusrbrown.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcusrbrown/marcusrbrown.github.io.git"
  },
  "license": "MIT",
  "author": "Marcus R. Brown <marcus@marcusrbrown.com>",
  "type": "module",
  "main": "src/main.tsx",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "fix": "eslint --fix",
    "lint": "eslint",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "setup-hooks": "simple-git-hooks",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,yaml}": [
      "eslint --fix"
    ]
  },
  "prettier": "@bfra.me/prettier-config/120-proof",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@bfra.me/eslint-config": "^0.50.0",
    "@bfra.me/prettier-config": "^0.16.0",
    "@bfra.me/tsconfig": "^0.12.0",
    "@eslint-react/eslint-plugin": "^2.0.0",
    "@playwright/test": "^1.58.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/eslint-plugin": "^1.3.9",
    "axe-core": "^4.11.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "happy-dom": "^20.0.0",
    "jiti": "^2.5.1",
    "lint-staged": "^16.1.2",
    "prettier": "^3.3.3",
    "simple-git-hooks": "^2.13.0",
    "tsx": "^4.20.3",
    "typescript": "^5.6.3",
    "vite": "^7.0.6",
    "vitest": "^4.0.0",
    "vitest-axe": "^0.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "^10.28.2"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2"
    }
  }
}
